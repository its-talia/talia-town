# Server
PORT=3001
NODE_ENV=development
SESSION_SECRET=changeme-at-least-32-characters-long!!

# Discord OAuth
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_app_client_secret
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# Database
# Production: set DATABASE_URL for Postgres (Fly.io managed)
# Local dev: leave DATABASE_URL unset to use SQLite automatically
# DATABASE_URL=postgresql://user:password@localhost:5432/talia_town
SQLITE_PATH=./data/talia-town.db

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:7723
OPENCLAW_GATEWAY_TOKEN=your_gateway_token

# Set to true for local dev without OpenClaw running
MOCK_MODE=true

# Client
CLIENT_URL=http://localhost:3000
